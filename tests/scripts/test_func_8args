void print_tab(int* T, int size){
    int i;
    i = 0;
    while(i < size){
        print(int, *(T + (i*8)));
        print(str, " , ");
        i = i +1;
    }
    return 0;
}


void shuffled(int* T, int size, int offset){
    int i;
    i = 0;
    while(i < size){
        T[i] = ( 5-(i + offset))*(i + offset)*( 10-(i + offset)) ;
        i = i + 1;
    }

    
    return 0;
}


int casse_tout(int a, int b, int c, int d, int e, int f, int h , int k){
    h = h + a + b + c - k;
    return h;
}