

main(){
    int** p1;
    int* b;
    b = malloc(8);
    *b = 3;
    p1 = f1(b);
    // Comme l'adressage a une porté locale sur b1, lorsque l'on accède à la contenu de p1, on obtient n'importe quoi
    print(int, **p1);
    
    return 0;
}

int** f1(int* b1){

    int** p;
    // La portée de l'adressage est limité au scope de la fonction, on prend l'adresse de b1 considéré comme une variable locale
    p = &b1;


    return p;
}