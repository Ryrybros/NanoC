main(){
    int* T;
    int s;
    s = 5;
    T = malloc(s*8);
    standard(T, s);
    print_tab(T, s);
    return 0;
}

void print_tab(int* T, int size){
    int i;
    i = 0;
    while(i < size){
        print(int, *(T + (i*8)));
        print(str, " , ");
        i = i +1;
    }
    return 0;
}

void standard(int* T, int size){
    int i;
    i = 0;
    while(i < size){
        *(T + (i*8)) = i*10;
        i = i + 1;
    }

    
    return 0;
}


