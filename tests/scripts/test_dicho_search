    int* R;
    int s;
    s = 10;
    T = malloc(s*8);
    T2 = malloc(s*8);
    int s2;
    s2 = 2*s*8;

    shuffled(T, s, 0);
    print_tab(T,s);
    
    mergeSort(T, 0, s - 1);

    s2 = 2*s;
    print(str,"Final  ");
    print_tab(T,s);
    print(str, "Look for 24 :  ");
    print(int, dichotomicSearch(T, 0,s - 1,24));
