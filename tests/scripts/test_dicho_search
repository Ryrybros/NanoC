void print_tab(int* T, int size){
    int i;
    i = 0;
    while(i < size){
        print(int, T[i]);
        print(str, " , ");
        i = i +1;
    }
    return 0;
}
void standard(int* T, int size, int offset){
    int i;
    i = 0;
    while(i < size){
        T[i] = i + offset;
        i = i + 1;
    }

    
    return 0;
}

void shuffled(int* T, int size, int offset){
    int i;
    i = 0;
    while(i < size){
        T[i] = ( 5-(i + offset))*(i + offset)*( 10-(i + offset)) ;
        i = i + 1;
    }

    
    return 0;
}

int* concat(int* A,int size_A,  int* B, int size_B, int* res){
    int i;
    i = 0;
    while(i < size_A){
        res[i] = A[i];
        i = i + 1;
    }
    while(i < (size_A + size_B)){
        res[i] = B[i - size_A];
        i = i +1;
    }
    return res;
}



void merge(int* arr, int left, int mid, int right) {
    
    int i;
    int j;
    int k;
    int n1;
    int n2;
    n1 = mid - left + 1;
    n2 = right - mid;

    
    int* leftArr;
    int* rightArr;
    leftArr = malloc(n1*8);
    rightArr = malloc(n2*8);

    
    i = 0;
    j = 0;
    while (i < n1){
        leftArr[i] = arr[left + i];
        i = i +1;
    }
    while(j < n2){  
        rightArr[j] = arr[mid + 1 + j];
        j = j +1;
    }
        

    
    i = 0;
    j = 0;
    k = left;
    while ( (i < n1) && (j < n2) ) {
            if ( leftArr[i] <= rightArr[j]) {
                arr[k] = leftArr[i];
                i = i +1;
            }
            else {
                arr[k] = rightArr[j];
                j= j+1;
            }
            k= k+1;
        
    }
    
    
    while (i < n1) {
        arr[k] = leftArr[i];
        i = i +1;
        k= k+1;
    }

    
    while (j < n2) {
        arr[k] = rightArr[j];
        j=j+1;
        k=k+1;
    }
    return 0;
}

void mergeSort(int* arr, int left, int right) {
    int mid; 
    

    if (left < right) {

        mid = left + ((right - left) / 2);

        
        
        mergeSort(arr, left, mid);
        mergeSort(arr, mid + 1, right);
        
    
        merge(arr, left, mid, right);
    }else{
        pass;
    }
    return 0;
}

int dichotomicSearch(int* T, int start, int end, int a) {
    if (start >= end) {
        return 0; 
    }else{
        pass;
    }

    
    if ((end - start) == 1) {
        if (T[start] == a) {
            return 1;
        } else {
            return 0;
        }
    }else{
        pass;
    }

    int mid;
    mid = start + ((end - start) / 2);

    if (T[mid] <= a) {
        
        return dichotomicSearch(T, mid, end, a);
    } else {
        
        return dichotomicSearch(T, start, mid, a);
    }
}