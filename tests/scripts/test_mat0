

main(){
    int n;
    n = 3;

    int* T1;
    int* T2;
    int* T3;
    
    T1 = malloc(n*8);
    T2 = malloc(n*8);
    T3 = malloc(n*8);
    standard(T1, n, 0);
    standard(T2, n, 10);
    standard(T3, n, -5);


    int** M;
    int** M2;
    int** M3;

    M = malloc(n*8);
    M2 = malloc(n*8);
    M3 = malloc(n*8);
    M3[0] = malloc(n*8);
    M3[1] = malloc(n*8);
    M3[2] = malloc(n*8);

    
    M[0] = T1;
    M[1] = T2;
    M[2] = T3;

      
    M2[0] = T1;
    M2[1] = T2;
    M2[2] = T3;
    

    multiply(M3, M, M2,n);
    print_mat(M, n);
    print(str, "endl");
    print_mat(M3, n);

    return 0;
}

void print_tab(int* T, int size){
    int i;
    i = 0;
    while(i < size){
        print(int, T[i]);
        print(str, " , ");
        i = i +1;
    }
    return 0;
}
void print_mat(int** M, int n){
    int i;
    i = 0;
    int j;
    while(i < n){
        j = 0;

        while(j < n){
            print(int, M[i][j]);
            print(str, " , ");
            j = j + 1;
        }
        print(str, "endl");
        i = i +1;
    }
    return 0;
}
void standard(int* T, int size, int offset){
    int i;
    i = 0;
    while(i < size){
        T[i] = i + offset;
        i = i + 1;
    }

    
    return 0;
}

void multiply(int** R, int** A, int** B, int n){
    int i;
    int j;
    int k;
    while(i < n){
        j = 0;
        while(j < n){
            R[i][j] = 0;
            
            k = 0;
            while(k < n){
                int a;
                int b;
                a = A[i][k];
                b = B[k][j];
                R[i][j] = R[i][j] + (a*b);
                k = k +1 ;
            }

            j = j + 1;
        }
        i = i +1;
    }  
    return 0;
}

void shuffled(int* T, int size, int offset){
    int i;
    i = 0;
    while(i < size){
        T[i] = ( 5-(i + offset))*(i + offset)*( 10-(i + offset)) ;
        i = i + 1;
    }

    
    return 0;
}
