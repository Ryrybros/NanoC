
OPBIN: /==|>=|<=|[+\-*\/<>]/
OPPTR: /[+\-]/
TYPE_STR : "str"
TYPE_INT : "int"
POINTER_ORDER : "*"+
ptr : "int" POINTER_ORDER
TAB_ORDER : ("[" NUMBER "]")+
tab : "int" TAB_ORDER -> int_tab
    | ptr TAB_ORDER   -> ptr_tab

type : "int" -> type_int
     | "str" -> type_str
     | ptr   -> type_ptr
     | "void" -> type_void
     | tab   -> type_tab

format   : TYPE_STR -> format_str
         | TYPE_INT -> format_int

deref :  POINTER_ORDER NAME -> single_deref | POINTER_ORDER "(" expression ")" -> expr_deref

exprstr : STRING -> str
        | NAME -> variable

tableau: "[" (NAME ",")* NAME "]"
   | "[" (SIGNED_NUMBER ",")* SIGNED_NUMBER "]"
   | "[" (tableau ",")* tableau "]"
eltab: NAME "[" expression "]" -> simple_tab
     | eltab "[" expression "]" -> tab_tab


expression : NAME -> variable
        | expression OPBIN expression -> bin
        | "(" expression ")" -> parenthesis
        | SIGNED_NUMBER -> int 
        | "null" -> nullptr
        | func_call -> function_call
        | deref -> dereferencing
        | eltab -> eltab_read

leftexpression : NAME -> variable | deref -> dereferencing | eltab -> eltab_write



start: func* main func*

parameter : type NAME -> parameter
arglist : ( parameter ",")* parameter | -> no_var
given_arglist : (expression "," )* expression |
return : "return " expression ";" -> return
if : "if" "(" expression ")" "{" command "}"
else: "else" "{" command "}"
command : leftexpression "=" expression ";" | leftexpression "=" tableau ";" -> assignment
        | leftexpression "=" "&" NAME ";" -> addressing
        | NAME "=" exprstr ";" -> assignement_str
        | leftexpression "=" "malloc(" expression ")" ";" -> allocation
        | command* command -> sequence
        | "pass" ";"    -> pass
        | if else -> if_else
        | if -> if_else
        | "while" "(" expression ")" "{"command"}"  -> while
        | "print" "(" format "," expression ")" ";" -> print
        | type NAME ";" -> declaration
        | func_call ";" -> function_call
        | "return" expression ";" -> return

main : "main" "(" arglist ")" "{" command* return "}"
func : "func " NAME "(" arglist ")" "{" command*"}" -> function
func_call : NAME "(" given_arglist ")" 

%import common.WS
%import common.SIGNED_NUMBER
%import common.NUMBER
%import common.CNAME -> NAME
%import common.ESCAPED_STRING -> STRING   
%ignore WS
