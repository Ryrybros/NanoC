
OPBIN: /[+\-*\/<>]/
TYPE_STR : "str"
TYPE_INT : "int"

TYPE_NAME : "int" | "str" | "ptr"
type   : TYPE_NAME

format   : TYPE_STR -> format_str
         | TYPE_INT -> format_int
         
expression :  NAME -> variable
            | SIGNED_NUMBER -> int
            | STRING -> str
            | expression OPBIN expression -> bin
            | "(" expression ")" -> parenthesis
            | func_call -> function_call

start: func* main func*

parameter : type NAME -> parameter
arglist : ( parameter ",")* parameter | -> no_var
given_arglist : (expression "," )* expression |
return : "return " expression ";" -> return
if : "if" "(" expression ")" "{" command "}"
else: "else" "{" command "}"
command : NAME "=" expression ";" -> assignment
        | command* command -> sequence
        | "pass" ";"    -> pass
        | if else -> if_else
        | if -> if_else
        | "while" "(" expression ")" "{"command"}"  -> while
        | "print" "(" format "," expression ")" ";"            -> print
        | type NAME ";" -> declaration
        | func_call ";" -> function_call
        | "return" expression ";" -> return

main : "main" "(" arglist ")" "{" command* return "}"
func : "func " NAME "(" arglist ")" "{" command*"}" -> function
func_call : NAME "(" given_arglist ")" 

%import common.WS
%import common.SIGNED_NUMBER
%import common.CNAME -> NAME
%import common.ESCAPED_STRING -> STRING   
%ignore WS
