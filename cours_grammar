IDENTIFIER: /[a-zA-Z_][a-zA-Z_0-9]*/
OPBIN: /[+\-*\/<>]/
TYPE_STR : "str"
TYPE_INT : "int"

format   : TYPE_STR -> format_str
         | TYPE_INT -> format_int
         
expression : IDENTIFIER -> variable
            | SIGNED_NUMBER -> int
            | STRING -> str
            | expression OPBIN expression -> bin


var : NAME -> variable
arglist : ( var ",")* var
return : "return" expression ";" -> return
if : "if" "(" expression ")" "{" command "}"
else: "else" "{" command "}"
command : IDENTIFIER "=" expression ";" -> assignment
        | command* command -> sequence
        | "pass" ";"    -> pass
        | if else -> if_else
        | if -> if_else
        | "while" "(" expression ")" "{"command"}"  -> while
        | "print" "(" format "," expression ")" ";"            -> print
        | "int" var ";" -> declaration
        | "str" var "=" ( STRING ) ";" -> declaration
        | "int" var "=" ( SIGNED_NUMBER | var ) ";" -> declaration 
        | func_call ";" -> function_call

main : "main" "(" arglist ")" "{" command* return "}" func*
func : "func " NAME "(" arglist ")" "{" command* return "}" -> function
func_call : NAME "()" 

%import common.WS
%import common.SIGNED_NUMBER
%import common.CNAME -> NAME
%import common.ESCAPED_STRING -> STRING   
%ignore WS
